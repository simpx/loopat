{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri/main/core/tauri-config-schema/schema.json",
  "productName": "loopat",
  "version": "0.1.0",
  "identifier": "ai.loopat.app",
  "build": {
    "devUrl": "http://localhost:7787",
    "frontendDist": "../loading"
  },
  "app": {
    "windows": [
      {
        "title": "loopat",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": true,
        "url": "/"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "dmg",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../dist-macos-x64/loopat",
      "../dist-macos-x64/loopat-sandbox",
      "../dist-macos-x64/claude",
      "../dist-macos-x64/mise",
      "../dist-macos-x64/git-crypt",
      "../dist-macos-x64/libcrypto.3.dylib"
    ]
  }
}
